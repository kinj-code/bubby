# Bubby Configuration
BUBBY_USE_LLM=1              # 1 = use local LLM, 0 = template-only mode
BUBBY_USE_TTS=0              # 1 = enable text-to-speech (requires Piper TTS)
BUBBY_LLM_PATH=              # Absolute path to a .gguf model file (e.g. models/llm/model.gguf)
                              # Overrides catalog selection. Leave empty to auto-select.
QT_QPA_PLATFORM=offscreen    # offscreen = headless daemon, wayland = GUI
